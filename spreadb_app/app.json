{
  "expo": {
    "name": "SpreadB",
    "slug": "spreadb_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#14A44D"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spreadb.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14A44D"
      },
      "package": "com.spreadb.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "spreadb",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
